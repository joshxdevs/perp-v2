// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id         Int        @id @default(autoincrement())
  username   String     @unique
  password   String
  available  Float      @default(0)
  locked     Float      @default(0)
  positions  Position[]
  orders     Order[]
  fillsMaker Fill[]     @relation("makerFills")
  fillsTaker Fill[]     @relation("takerFills")
}

model Position {
  id               Int    @id @default(autoincrement())
  userId           Int
  user             User   @relation(fields: [userId], references: [id])
  marketId         String
  type             String // "LONG" || "SHORT"
  qty              Float
  margin           Float
  liquidationPrice Float
  averagePrice     Float
}

model Order {
  id        Int    @id @default(autoincrement())
  userId    Int
  user      User   @relation(fields: [userId], references: [id])
  marketId  String
  type      String
  qty       Float
  filledQty Float  @default(0)
  margin    Float
  orderType String
  price     Float?
  status    String
}

model Fill {
  id       Int    @id @default(autoincrement())
  makerId  Int
  takerId  Int
  maker    User   @relation("makerFills", fields: [makerId], references: [id])
  taker    User   @relation("takerFills", fields: [takerId], references: [id])
  marketId String
  qty      Float
  price    Float
  longId   Int
  shortId  Int
}
